<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.ibroadcast.nowplaying"
       name="iBroadcast Now Playing"
       version="1.0.0"
       provider-name="FOBO">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.script" library="default.py"/>
  <extension point="xbmc.addon.metadata">
    <assets>
      <icon>icon.png</icon>
    </assets>
    <summary lang="en_GB">Now Playing</summary>
    <description lang="en_GB">Full-screen album art display for the currently playing track.</description>
    <platform>all</platform>
  </extension>
</addon>
